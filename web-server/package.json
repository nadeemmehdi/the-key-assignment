{
  "name": "web-server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/dev-server.ts",
    "build": "esbuild src/dev-server.ts --bundle --platform=node --format=esm --outfile=dist/server.js",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "tsx": "^4.23.0",
    "vitest": "^4.1.10"
  }
}
